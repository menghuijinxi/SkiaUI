{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-vcpkg",
      "displayName": "Visual Studio 2026 (vcpkg)",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../out/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "SKIATEST_USE_SKIA_D3D": "ON"
      }
    },
    {
      "name": "ninja-vcpkg",
      "displayName": "Ninja (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/ninja-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../out/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "SKIATEST_USE_SKIA_D3D": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vcpkg-release",
      "configurePreset": "windows-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "ninja-vcpkg-release",
      "configurePreset": "ninja-vcpkg"
    }
  ]
}
